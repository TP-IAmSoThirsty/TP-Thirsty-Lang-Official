// Governed Agent Runner Example
// Demonstrates governed mode: a `requires` precondition is enforced on every
// call, and a plain orchestrator wraps work in spillage/cleanup + cascade.

module governed_agent: governed

// Governed function: the precondition is enforced at every call site.
glass validate(token) requires length(token) > 0 {
    return "valid:" + token
}

glass process_data(data) {
    return "processed: " + data
}

glass governed_action(action_name, data) {
    spillage {
        drink checked = validate(data)
        drink result = cascade process_data(data)
        return result
    } error {
        return "failed: " + action_name
    }
    cleanup {
        return action_name
    } finally {
        return action_name
    }
}

// Main governed agent run
drink result = governed_action("test_action", "sample data")
pour result
